local Players = game:GetService("Players")

local mensagem = "Script disabled for updates. Join our Discord server for more information https://discord.gg/cuNQpTjGVT"

Players.PlayerAdded:Connect(function(player)
    player:Kick(mensagem)
end)

for _, player in ipairs(Players:GetPlayers()) do
    player:Kick(mensagem)
end
